{
  "name": "@amigo-ai/platform-sdk",
  "version": "0.2.1",
  "description": "Official TypeScript SDK for the Amigo Platform API",
  "keywords": [
    "amigo",
    "platform",
    "sdk",
    "ai",
    "voice",
    "world-model"
  ],
  "homepage": "https://github.com/amigo-ai/amigo-platform-typescript-sdk",
  "bugs": {
    "url": "https://github.com/amigo-ai/amigo-platform-typescript-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-ai/amigo-platform-typescript-sdk.git"
  },
  "license": "MIT",
  "author": "Amigo AI",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "gen-types": "node scripts/gen-types.mjs",
    "build": "npm run clean && npm run gen-types && npm run esbuild && tsc --project tsconfig.build.json",
    "esbuild": "node scripts/build.mjs",
    "lint": "eslint 'src/**/*.{ts,tsx}' --max-warnings 0",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run tests/resources tests/core",
    "test:dist": "vitest run tests/dist",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "test:watch": "vitest tests/resources tests/core",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "sideEffects": false,
  "dependencies": {
    "@rolldown/binding-darwin-arm64": "^1.0.0-rc.16",
    "openapi-fetch": "^0.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "msw": "^2.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
